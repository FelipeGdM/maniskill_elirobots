// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
	"name": "CPU",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"build": {
		// Path is relative to the devcontainer.json file.
		"dockerfile": "Dockerfile",
		"context": "../.."
	},
	"runArgs": [
		"--privileged",
		"--device=/dev/dri:/dev/dri",
		"--ipc=host"
		// "-v /usr/share/vulkan/icd.d/intel_icd.x86_64.json:/usr/share/vulkan/icd.d/intel_icd.x86_64.json:ro"
		// "--device /dev/dri"
	],
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-azuretools.vscode-containers",
				"detachhead.basedpyright",
				"tamasfe.even-better-toml",
				"ms-python.vscode-pylance",
				"ms-python.python",
				"ms-python.debugpy",
				"ms-python.vscode-python-envs",
				"charliermarsh.ruff",
				"redhat.vscode-xml",
				"ms-vscode-remote.remote-ssh"
			]
		}
	},
	"mounts": [
		"source=/run/user/1000/wayland-0,target=/run/user/1000/wayland-0,type=bind",
		// Optional: mount the entire runtime dir if needed
		"source=/run/user/1000,target=/run/user/1000,type=bind",
		"source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind",
		"source=${env:XAUTHORITY},target=/root/.Xauthority,type=bind,readonly"
	],
	// Environment variables for Wayland
	"containerEnv": {
		"WAYLAND_DISPLAY": "wayland-0",
		"XDG_RUNTIME_DIR": "/run/user/1000",
		"DISPLAY": "${localEnv:DISPLAY}"
		// "VK_ICD_FILENAMES": "/usr/share/vulkan/icd.d/intel_icd.x86_64.json"
	},
	"postCreateCommand": "poetry install"
	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},
	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],
	// Use 'postCreateCommand' to run commands after the container is created.
	// "postCreateCommand": "pip3 install --user -r requirements.txt",
	// Configure tool-specific properties.
	// "customizations": {},
	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}