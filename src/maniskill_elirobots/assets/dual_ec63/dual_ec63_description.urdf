            <origin xyz="0 0 0" rpy="0 0 0" />
            <mass value="0.0328" />
            <!-- Inertia computed about finger origin, including both boxes -->
            <inertia ixx="1.399e-5" ixy="0" ixz="-2.5e-6" iyy="1.438e-5" iyz="0" izz="7.433e-7" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.005 0.008 0.016" />
            </geometry>
            <material name="r2_finger_material" />
        </visual>
        <visual>
            <origin xyz="0.005 0 0.025" rpy="0 0 0" />
            <geometry>
                <box size="0.005 0.008 0.025" />
            </geometry>
            <material name="r2_finger_ext_material" />
        </visual>
        <collision>
            <origin xyz="0.005 0 0.025" rpy="0 0 0" />
            <geometry>
                <box size="0.005 0.008 0.025" />
            </geometry>
        </collision>
    </link>

    <!-- Finger 2 (left) -->
    <link name="r2_claw_finger_2">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <mass value="0.0328" />
            <!-- Inertia is symmetric to finger 1 (but mirrored in x) -->
            <inertia ixx="1.399e-5" ixy="0" ixz="2.5e-6" iyy="1.438e-5" iyz="0" izz="7.433e-7" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.005 0.008 0.016" />
            </geometry>
            <material name="r2_finger_material" />
        </visual>
        <visual>
            <origin xyz="-0.005 0 0.025" rpy="0 0 0" />
            <geometry>
                <box size="0.005 0.008 0.025" />
            </geometry>
            <material name="r2_finger_ext_material" />
        </visual>
        <collision>
            <origin xyz="-0.005 0 0.025" rpy="0 0 0" />
            <geometry>
                <box size="0.005 0.008 0.025" />
            </geometry>
        </collision>
    </link>

    <!-- Joint for finger 1 (prismatic along negative X) -->
    <joint name="r2_finger_1_joint" type="prismatic">
        <parent link="r2_claw_base" />
        <child link="r2_claw_finger_1" />
        <origin xyz="0.02 0 0.042" rpy="0 0 0" />
        <axis xyz="-1 0 0" />
        <limit lower="0" upper="0.01" effort="10" velocity="0.1" />
        <dynamics damping="0.1" friction="0.0" />
    </joint>

    <!-- Joint for finger 2 (prismatic along positive X) -->
    <joint name="r2_finger_2_joint" type="prismatic">
        <parent link="r2_claw_base" />
        <child link="r2_claw_finger_2" />
        <origin xyz="-0.02 0 0.042" rpy="0 0 0" />
        <axis xyz="1 0 0" />
        <limit lower="0" upper="0.01" effort="10" velocity="0.1" />
        <dynamics damping="0.1" friction="0.0" />
    </joint>
</robot>